# Dependencies
node_modules/
**/node_modules/

# Next.js build output
app/.next/
app/out/

# Results DB — lives on Railway volume, NEVER commit
app/results.sqlite
app/results.sqlite-wal
app/results.sqlite-shm

# SQLite WAL/journal files (auto-generated, never commit)
*.sqlite-wal
*.sqlite-shm

# Backup / intermediate DBs in db/ folder (app/matura.sqlite IS tracked)
db/*.sqlite

# Extracted text files (large, regeneratable)
data/output_full.txt
data/english_output.txt

# Environment
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# Logs
*.log
dev-server.log

# PDF files (large, not needed in repo — except public/ catalog PDFs)
*.pdf
!app/public/*.pdf

# Temp
*.tmp
pdf_extract_temp/
